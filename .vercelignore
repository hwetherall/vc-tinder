# Keep the Vercel deployment lean: exclude data files, docs, backups and
# non-runtime scripts. The runtime import graph (server.mjs -> csv/db/tiers/
# importer/discover/exa/llm) and browser assets (index.html, styles.css,
# app.js, csv.mjs, tiers.mjs) must NOT be listed here.
*.csv
*.xlsx
*.log
*.test.mjs
backups/
exports/
